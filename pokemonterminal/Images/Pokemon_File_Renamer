def get_pokemon_name(dex_number):
    with open('/home/mark/Documents/Adams_Dev_Test/Pokemon-Terminal/pokemonterminal/Data/pokemon.txt') as f:
        lines = f.readlines()
        if 0 < dex_number <= len(lines):
            return lines[dex_number - 1].strip()
    return None
